APP_NAME="Template Project"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.domena.cz

APP_LOCALE=cs
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=cs_CZ
APP_TIMEZONE=Europe/Prague

LOG_CHANNEL=stack
LOG_LEVEL=error

# DATABÁZE
DB_CONNECTION=mysql
DB_HOST=a000um.forpsi.com
DB_PORT=3306
DB_DATABASE=f00000
DB_USERNAME=f00000
DB_PASSWORD="password"

# STORAGE & SESSIONS
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

# POŠTA
MAIL_MAILER=smtp
MAIL_HOST=smtp.forpsi.com
MAIL_PORT=587
MAIL_USERNAME=info@domena.cz
MAIL_PASSWORD="password"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="info@domena.cz"
MAIL_FROM_NAME="${APP_NAME}"

# --- POKROČILÉ NASTAVENÍ (Volitelné) ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

# VITE (Pokud používáš React/Vue/Tailwind přes Vite)
VITE_APP_NAME="${APP_NAME}"